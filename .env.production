# ============================================================================
# 生产环境配置模板
# ============================================================================
# 这个文件会被推到 GitHub（不含真实密钥，只是模板）
# 服务器上的真实 .env 不进 git，手动维护
#
# 在服务器 /opt/interview-guide/.env 里填真实值
# ============================================================================

# 阿里云百炼 API Key（LLM + Embedding + ASR + TTS）
AI_BAILIAN_API_KEY=your_dashscope_api_key_here

# Provider Key 加密密钥（部署后不要改，改了已存的密钥会解不开）
APP_AI_CONFIG_ENCRYPTION_KEY=your_encryption_key_here

# AI 模型
AI_MODEL=qwen3.5-flash

# PostgreSQL 密码（对齐 docker-compose.yml 默认值）
POSTGRES_PASSWORD=password

# ACR 地址（docker-compose.yml 用这个变量拼镜像路径）
ACR_REGISTRY=crpi-tpudmz0tztfynq35.cn-guangzhou.personal.cr.aliyuncs.com
